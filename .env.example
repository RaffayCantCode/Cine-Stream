# Database - Neon Postgres (or any Postgres)
# Copy this from your Neon dashboard
DATABASE_URL="postgres://user:password@host.neon.tech/database?sslmode=require"

# NextAuth.js Secret - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# TMDB API Key - Bearer token for read access
# Get from: https://www.themoviedb.org/settings/api
TMDB_API_KEY="your-tmdb-bearer-token"

# OAuth Providers (Optional - for social login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Contact Form Email (Gmail SMTP - required for the /contact page to work)
# Enable 2FA on your Gmail, then create an App Password at https://myaccount.google.com/apppasswords
CONTACT_EMAIL="asifraffy@gmail.com"
GMAIL_USER="asifraffy@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"
